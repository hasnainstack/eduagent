# ── AI — LLM (provide at least one) ──
GROQ_API_KEY=                           # gsk_... — https://console.groq.com
GEMINI_API_KEY=                         # AIzaSy... — https://aistudio.google.com

# ── Voice ──
DEEPGRAM_API_KEY=                       # https://console.deepgram.com
ELEVENLABS_API_KEY=                     # https://elevenlabs.io
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel voice

# ── App ──
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://eduagent-zeta.vercel.app
AGENT_TIMEOUT_SECONDS=30

# ── Auth — change in production! Use `openssl rand -hex 32` ──
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Database ──
# Local dev: uses SQLite by default (omit DATABASE_URL)
# Production (Render + Supabase): DATABASE_URL points to Supabase PostgreSQL
DATABASE_URL=                           # postgresql://user:pass@host:5432/postgres
SQLITE_PATH=                            # fallback SQLite path (defaults to backend/db/eduagent.db)

# ── Error monitoring (optional) ──
SENTRY_DSN=                             # https://xxx@xxx.ingest.us.sentry.io/xxx
